# expected.env — Soll-Werte fuer den Seam-Watcher (seam-watch.sh) +
# Deploy-Verifier (deploy.sh). Prinzip: gemessen-statt-geglaubt.
# Hier steht der Erwartungswert, gegen den die LIVE-Naht verglichen wird.
# Drift = (Live != Soll). UNREACHABLE ist ein eigener Zustand, KEIN gruen.
#
# Diese Datei ist die einzige Stelle, an der "was soll laufen" deklariert ist.
# Aendert sich das Brain bewusst, aendert sich HIER der Soll-Wert — sonst
# schlaegt der Waechter zu Recht Alarm.

# --- Brain ------------------------------------------------------------------
# Substring-Match gegen das gemessene /health .model-Feld des e4b-Sidecars.
# Live misst z.B. "mlx-community/gemma-4-e4b-it-4bit" -> muss diesen Token
# enthalten. 16-GB-Wand-Invariante: es laeuft IMMER nur EIN Brain resident.
EXPECTED_BRAIN=gemma-4-e4b-it-4bit

# --- Auth-Wand (Perimeter / Trust-Kernel) -----------------------------------
# /api/v1/speakers MUSS ohne Token mit diesem Code antworten.
# 200 hier = Perimeter offen = harte Sicherheits-Drift (rote Karte).
AUTH_WALL=401

# --- Backend ----------------------------------------------------------------
# /api/health .status Soll-Wert des ct-106-Backends.
EXPECTED_BACKEND_STATUS=up
